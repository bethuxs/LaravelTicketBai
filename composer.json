{
    "name": "ebethus/laravel-ticketbai",
    "description": "TicketBai Library for Laravel",
    "type": "library",
    "require": {
        "php": "^8.2",
        "barnetik/ticketbai": "dev-main",
        "simplesoftwareio/simple-qrcode": "4.2",
        "cweagans/composer-patches": "^1.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0",
        "phpstan/phpstan": "^1.10",
        "laravel/pint": "^1.13",
        "larastan/larastan": "2.x-dev"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "EBethus\\LaravelTicketBAI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EBethus\\LaravelTicketBAI\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "ashrey",
            "email": "alberroteran@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "config": {
        "allow-plugins": {
            "cweagans/composer-patches": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse",
        "format": "pint"
    },
    "extra": {
        "patches": {
            "barnetik/ticketbai": {
                "Fix certificate validation in AbstractTicketBai.sign() method": "patches/barnetik-ticketbai-certificate-validation.patch"
            }
        },
        "laravel": {
            "providers": [
                "EBethus\\LaravelTicketBAI\\TicketBAIProvider"
            ],
            "aliases": {
                "TicketBAI": "EBethus\\LaravelTicketBAI\\Facade\\TicketBAI"
            }
        }
    }
}
